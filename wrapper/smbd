#!/bin/sh
# /usr/local/sbin/smbd — Samba 4.1.23 start wrapper
#
# Buffalo firmware calls /usr/local/sbin/smbd (the Samba 3 binary location).
# This wrapper redirects to the Samba 4 binary and sets the library search
# path so that the Samba 4 shared libraries are found before the system ones.
#
# Install: cp smbd /usr/local/sbin/smbd && chmod +x /usr/local/sbin/smbd
export LD_LIBRARY_PATH=/usr/local/samba4/lib:/usr/local/samba4/lib/private
exec /usr/local/samba4/sbin/smbd -s /etc/samba/smb.conf "$@"
