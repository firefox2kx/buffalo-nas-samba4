#!/bin/sh
# /usr/local/sbin/smbd — Samba 4.1.23 start wrapper
#
# Buffalo firmware calls /usr/local/sbin/smbd (the Samba 3 binary location).
# This wrapper redirects to the Samba 4 binary, sets the library search path,
# and passes the VFS module directory explicitly so that the binary works
# regardless of where it was cross-compiled.
#
# Install: cp smbd /usr/local/sbin/smbd && chmod +x /usr/local/sbin/smbd
export LD_LIBRARY_PATH=/usr/local/samba4/lib:/usr/local/samba4/lib/private
exec /usr/local/samba4/sbin/smbd \
    -s /etc/samba/smb.conf \
    --modulesdir=/usr/local/samba4/modules \
    "$@"
